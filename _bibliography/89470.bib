article_type = {journal},
title = {Improved inference of population histories by integrating genomic and epigenomic data},
author = {Sellinger, Thibaut and Johannes, Frank and Tellier, Aurélien},
editor = {Castric, Vincent and Dalal, Yamini},
volume = 12,
year = 2024,
month = {sep},
